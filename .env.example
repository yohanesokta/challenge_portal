# Database connection string
DATABASE_URL=mysql://root:root@db:3306/coding_platform

# MariaDB / MySQL configuration (for Docker Compose)
MARIADB_ROOT_PASSWORD=root
MARIADB_DATABASE=coding_platform

# NextAuth configuration
# For NextAuth v5, use AUTH_SECRET instead of NEXTAUTH_SECRET
# You can generate a secret with: npx auth secret
AUTH_SECRET=
# The base URL of your application (required for production)
AUTH_URL=http://localhost:3000

# Google OAuth credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Feature flags
# Set to 'true' to enable authentication (Google and Credentials)
APP_USING_AUTH=false

# Node environment (development, production, or test)
NODE_ENV=development

# Next.js Telemetry (set to 1 to disable)
NEXT_TELEMETRY_DISABLED=1
